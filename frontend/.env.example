# Base URL for your API (no trailing slash). Used by the centralized Axios client.
VITE_API_BASE_URL=http://localhost:8000

# Razorpay Key Id (public) — same value as RAZORPAY_KEY_ID on the API.
VITE_RAZORPAY_KEY_ID=

# Public support email (shown on /contact). Optional but recommended before launch.
# VITE_PUBLIC_SUPPORT_EMAIL=hello@yourdomain.com
