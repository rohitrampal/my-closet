# Copy to `.env` and adjust. Pydantic loads `.env` from the project root (backend/).

DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/appdb
SECRET_KEY=change-me-to-a-long-random-string-at-least-16-chars
ENV=dev

# JWT access token lifetime (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Comma-separated origins, or * (dev only; do not use * with credentials in browsers)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

LOG_LEVEL=INFO

# Optional: LLM stylist (POST /outfit/assistant) — natural-language parse + explanations
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# In-memory caches (matcher ML scores, outfit responses, image tagging); default TTL 480s, max 2048 entries each
# MEMORY_CACHE_TTL_SECONDS=480
# MEMORY_CACHE_MAX_ENTRIES=2048

# Recent outfit triples per user (repeat avoidance in matcher); default last 5 outfits, 10m TTL, -2 score penalty
# OUTFIT_REPEAT_HISTORY_MAX=5
# OUTFIT_REPEAT_HISTORY_TTL_SECONDS=600
# OUTFIT_REPEAT_PENALTY=2.0
