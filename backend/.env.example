# Copy to `.env` and adjust. Pydantic loads `.env` from the project root (backend/).

DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/appdb
SECRET_KEY=change-me-to-a-long-random-string-at-least-16-chars
ENV=dev

# JWT access token lifetime (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Comma-separated origins, or * (dev only; do not use * with credentials in browsers)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

LOG_LEVEL=INFO

# AWS S3 — garment images (use IAM user keys, instance role, etc.; see boto3 credential chain)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=your-bucket-name
# AWS_S3_REGION=us-east-1
# Optional: CloudFront or custom domain (no trailing slash) for URLs saved in the DB
# AWS_S3_PUBLIC_BASE_URL=https://d123456abcdef.cloudfront.net
# Optional: LocalStack / custom S3 endpoint
# AWS_ENDPOINT_URL_S3=http://localhost:4566

# Optional: Gemini Vision for POST /clothes/analyze (falls back to local vision if unset)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# (Use a model id your key supports; short names like gemini-1.5-flash may 404 on the current API.)
# GEMINI_DISABLED=true
# (Skip Gemini entirely when daily free quota is used up; use OPENAI_API_KEY for /clothes/analyze or rely on local fallback.)

# Optional: LLM stylist (POST /outfit/assistant) — natural-language parse + explanations
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
# Optional: vision model for POST /clothes/analyze when Gemini fails or is unset (defaults to OPENAI_MODEL)
# OPENAI_VISION_MODEL=gpt-4o-mini

# POST /clothes/analyze — multi-provider chain (each step times out separately, then next provider):
# gemini → groq → huggingface (HF router) → sarvam → openai → local Pillow heuristics
# VISION_STEP_TIMEOUT_SECONDS=60
# VISION_MIN_ACCEPT_CONFIDENCE=0.6
# VISION_CIRCUIT_FAILURE_THRESHOLD=5
# VISION_CIRCUIT_COOLDOWN_SECONDS=600
# VISION_FAST_PATH_ENABLED=true
# VISION_FAST_PATH_EDGE_MAX=12
# VISION_FAST_PATH_COLOR_SHARE_MIN=0.78
# GROQ_API_KEY=
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# Use Llama 4 Scout for vision (llama-3.2-*-vision-preview IDs are decommissioned on Groq).
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# HF_API_TOKEN=
# HF_VISION_BASE_URL=https://router.huggingface.co/v1
# Router must expose a VLM your token can run (enable Inference Providers / model license as needed).
# HF_VISION_MODEL=Qwen/Qwen2-VL-2B-Instruct
# SARVAM_API_KEY=
# SARVAM_BASE_URL=https://api.sarvam.ai/v1
# SARVAM_MODEL=sarvam-30b
# Sarvam uses text + local pixel hints only (API does not accept OpenAI multimodal message content).
# SARVAM_VISION_MODEL=

# In-memory caches (matcher ML scores, outfit responses, image tagging); default TTL 480s, max 2048 entries each
# MEMORY_CACHE_TTL_SECONDS=480
# MEMORY_CACHE_MAX_ENTRIES=2048

# Recent outfit triples per user (repeat avoidance in matcher); default last 5 outfits, 10m TTL, -2 score penalty
# OUTFIT_REPEAT_HISTORY_MAX=5
# OUTFIT_REPEAT_HISTORY_TTL_SECONDS=600
# OUTFIT_REPEAT_PENALTY=2.0

# Razorpay (premium checkout — POST /payment/*)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# Webhook signing secret (Dashboard → Webhooks → your endpoint secret)
# RAZORPAY_WEBHOOK_SECRET=

# Premium pricing (GET /payment/config, POST /payment/create-order). Use PRICING_MODE=test for low test checkouts.
PRICING_MODE=prod
PREMIUM_PRICE_INR=49
TEST_PRICE_INR=1

# SPA URL for password-reset links in emails (POST /auth/forgot-password). No trailing slash.
# FRONTEND_BASE_URL=http://localhost:5173

# Contact form — POST /contact (SMTP). If any of these are unset, /contact returns 503.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# If the app password has spaces, quote it (especially for docker compose ${VAR} substitution):
# SMTP_PASSWORD="xxxx xxxx xxxx xxxx"
# ADMIN_EMAIL=your-email@gmail.com
